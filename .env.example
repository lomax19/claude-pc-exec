# Copiez en .env et remplissez. Générer un token : openssl rand -hex 32
EXEC_API_TOKEN=remplacez_par_votre_token_secret

# Optionnel (valeurs par défaut sûres) :
# EXEC_API_HOST=127.0.0.1     # laisser en localhost si derrière tunnel (recommandé)
# EXEC_API_PORT=5555
# EXEC_API_TIMEOUT=30
# EXEC_API_CWD=/home/utilisateur
